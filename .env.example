# Gemini API 키 - https://aistudio.google.com/ 에서 발급
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# HuggingFace 토큰 - https://huggingface.co/settings/tokens 에서 발급
# pyannote/speaker-diarization-3.1 모델 사용 동의 필요:
# https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=여기에_HuggingFace_토큰_입력

# 사용할 LLM 모델
MODEL=gemini/gemini-2.0-flash

# CrewAI 추적 비활성화 (선택사항)
CREWAI_TRACING_ENABLED=false

# 캡컷 프로젝트 출력 폴더 (GUI에서 설정 가능, 비워두면 기본값 사용)
CAPCUT_OUTPUT_DIR=
